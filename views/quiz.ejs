<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Word Quiz</title>

    <% if (score !== null) { %>
        <meta http-equiv="refresh" content="1; url=/quiz">
    <% } %>
</head>

<body style="background-color: white; font-family: serif;">

    <h1>Word Quiz!</h1>

    <h2><%= correctWord %> - <%= correctPart %></h2>

    <% if (score !== null) { %>
        <h3><%= score %></h3>
    <% } %>

    <form action="/quiz" method="POST">

        <input type="hidden" name="correctWord" value="<%= correctWord %>">
        <input type="hidden" name="correctPart" value="<%= correctPart %>">
        <input type="hidden" name="correctDef" value="<%= correctDef %>">

        <ol>
            <% definitions.forEach(function(definition) { %>
                <li>
                    <label>
                        <input type="radio" name="selectedDef" value="<%= definition %>" required>
                        <%= definition %>
                    </label>
                </li>

                <input type="hidden" name="definitions" value="<%= definition %>">
            <% }) %>
        </ol>

        <% if (score === null) { %>
            <button type="submit">Submit</button>
        <% } %>

    </form>

</body>
</html>