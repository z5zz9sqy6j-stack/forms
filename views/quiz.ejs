<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Word Quiz</title>
</head>
<body style="background-color: white; font-family: serif;">

    <%
        let questionCount = totalQuestions ?? 0;
        let score = totalCorrect ?? 0;

        let randomIndex = parseInt(Math.random() * chosenWords.length);
        let chosenWord = chosenWords[randomIndex];
        let [correctWord, correctPart, correctDef] = chosenWord.split('\t');
    %>

    <% if (questionCount == 0) { %>
        <h1>Welcome to the word quiz!</h1>
    <% } else { %>
        <h1>Score: <%= score %> / <%= questionCount %></h1>
    <% } %>

    <h2><%= correctWord %> - <%= correctPart %></h2>

    <form action="/quiz" method="POST">
        <ol>
            <% for (currentWord of chosenWords) { %>
                <%
                    let [word, part, def] = currentWord.split('\t');
                %>
                <li>
                    <label>
                        <input type="radio" name="userChoice" value="<%= def %>" required>
                        <%= def %>
                    </label>
                </li>
            <% } %>
        </ol>

        <input type="hidden" name="correctDef" value="<%= correctDef %>">
        <input type="hidden" name="totalQuestions" value="<%= questionCount %>">
        <input type="hidden" name="totalCorrect" value="<%= score %>">

        <input type="submit" value="Submit Answer!">
    </form>

</body>
</html>