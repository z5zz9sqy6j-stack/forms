<!DOCTYPE html>
<html>
<head>
    <title>Quiz</title>
</head>
<body>
    <h1>Quiz Words</h1>

    <% chosenWords.forEach(wordObj => { %>
        <div style="margin-bottom: 20px;">
            <h3><%= wordObj.word %></h3>
            <p><strong>Part:</strong> <%= wordObj.part %></p>
            <p><strong>Definition:</strong> <%= wordObj.def %></p>
        </div>
    <% }) %>
</body>
</html>